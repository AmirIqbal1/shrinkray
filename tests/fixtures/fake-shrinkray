#!/usr/bin/env bash
set -euo pipefail

input="${1:?input is required}"
shift
container="mkv"
while [ "$#" -gt 0 ]; do
  case "$1" in
    --size|--quality)
      shift 2
      ;;
    --container)
      container="$2"
      shift 2
      ;;
    --keep-all-audio)
      shift
      ;;
    *)
      printf 'unexpected fake shrinkray argument: %s\n' "$1" >&2
      exit 2
      ;;
  esac
done

output="${input%.*}.shrunk.${container}"
printf '==> Encoding with HEVC (pass 1 of 2)...\n'
sleep 0.15
printf '==> Encoding with HEVC (pass 2 of 2)...\n'
sleep 0.15
printf '==> Validating output...\n'
cp -- "$input" "$output"
